// GFG: Floor Square Root
// Topic: Binary Search
// Difficulty: Easy
// Time Complexity: O(log n)
// Space Complexity: O(1)

class Solution {
    int floorSqrt(int n) {
       
       int str = 1, end = n, root = 1;
       
       while (str <= end) {
           int mid = str + (end - str) / 2;
           int sqr = mid * mid;

           if (sqr == n) return mid;
           else if (sqr < n) {   
               root = mid;
               str = mid + 1;            
           } else {
               end = mid - 1;            
           }
       }
       
       return root;  
    }
}
