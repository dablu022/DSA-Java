class Solution {
    public int peakIndexInMountainArray(int[] arr) {
        int n= arr.length;
        int str=1 , end=n-2;
        while(str<=end){
            int mid= str +( end-str)/2;
          if(arr[mid]>arr[mid-1] && arr[mid]>arr[mid+1]) return mid;
            else if(arr[mid]> arr[mid-1]&& arr[mid]<arr[mid+1]){
                str =mid+1;
            }else{
                end =mid-1;
            
            }
            
        }
       return -1;
    }
}
